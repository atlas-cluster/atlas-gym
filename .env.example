# Database Configuration
# Copy this file to .env and update with your actual credentials

# PostgreSQL Database URL
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=SCHEMA
# 
# Local Development:
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/atlas_gym?schema=public"
#
# Production (SSH Deployment):
# DATABASE_URL="postgresql://USER:PASSWORD@YOUR_SERVER_IP:5432/atlas_gym?schema=public"
