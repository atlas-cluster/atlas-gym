# Database Configuration
POSTGRES_USER=atlas_user
POSTGRES_PASSWORD=atlas_password
POSTGRES_DB=atlas_gym
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Optional: Database connection pool settings (defaults shown)
# DB_POOL_MAX=20
# DB_IDLE_TIMEOUT_MS=30000
# DB_CONNECTION_TIMEOUT_MS=2000

# Note: You can also use a single DATABASE_URL instead of individual variables
# DATABASE_URL=postgresql://atlas_user:atlas_password@localhost:5432/atlas_gym
